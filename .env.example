# Copy this file to .env in the repo root before running `npm run dev`.
# All variables are validated at server startup — missing values fail fast.

# Where Prisma writes the SQLite database file (relative to /server).
DATABASE_URL="file:./dev.db"

# Secret used to sign JWTs. Use a long random string in any non-local environment.
JWT_SECRET="change-me-to-a-long-random-string"

# Port the Express API listens on.
PORT=3001

# Origin allowed by CORS (the Vite dev server's URL in development).
CLIENT_ORIGIN="http://localhost:5173"

# Set to "production" in production. Affects cookie `secure` flag and error verbosity.
NODE_ENV="development"
