// Catchable data model. SQLite for zero-install portability; tables are snake_case via @@map.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  username     String   @unique
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")

  preferences  UserPreference?
  choices      PokemonChoice[]
  achievements UserAchievement[]

  @@map("users")
}

model UserPreference {
  userId String @id @map("user_id")
  // SQLite has no JSON column: list-valued prefs are stored comma-separated
  // and round-tripped via encode/decode helpers. `difficulties` is a subset
  // of 'easy'|'medium'|'hard'|'legendary'; empty string means "all".
  regions      String
  types        String
  difficulties String @default("")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_preferences")
}

model PokemonChoice {
  id        Int      @id @default(autoincrement())
  userId    String   @map("user_id")
  pokemonId Int      @map("pokemon_id")
  // 'like'|'dislike'|'fled', validated at the app layer.
  // 'fled' = missed the catch minigame; deck loader excludes it for 5 minutes.
  choice    String
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, pokemonId])
  @@index([userId, choice])
  @@map("pokemon_choices")
}

// Per-user achievement unlocks. Definitions live in code
// (server/src/lib/achievements/catalog.ts) so they can change without migrations.
model UserAchievement {
  id            String   @id @default(cuid())
  userId        String   @map("user_id")
  achievementId String   @map("achievement_id")
  unlockedAt    DateTime @default(now()) @map("unlocked_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@index([userId])
  @@map("user_achievements")
}
